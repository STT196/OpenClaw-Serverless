apiVersion: http.keda.sh/v1alpha1
kind: HTTPScaledObject
metadata:
  name: openclaw-http-scaler
  namespace: openclaw
spec:
  host: openclaw.localhost.com        # singular "host"

  replicas:
    min: 1
    max: 5

  targetPendingRequests: 100

  scaleTargetRef:
    name: openclaw-serverless
    kind: Deployment
    apiVersion: apps/v1
    service: openclaw-service
    port: 18789